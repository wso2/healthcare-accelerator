# consent-app-bff-v2 Configuration Template
# Copy to Config.toml and fill in your values.

hostname = "localhost"
port = 9092
corsAllowedOrigin = "http://localhost:5176"

# IDP base URL — works for both WSO2 IS and Asgardeo
# WSO2 IS example:   "https://localhost:9443"
# Asgardeo example:  "https://api.asgardeo.io/t/mytenant"
idpBaseUrl = "https://localhost:9443"

# Leave empty to default to {idpBaseUrl}/oauth2/token
idpTokenEndpoint = ""

clientId = "<oauth2-client-id>"
clientSecret = "<oauth2-client-secret>"   # also used as JWT signing secret

# Consent flow:
#   "scope"   — all apps use SMART scope flow
#   "purpose" — all apps use purpose+element flow
#   "auto"    — determine flow per client_id using scopeConsentedApps / purposeConsentedApps below
consentFlow = "scope"

# Only used when consentFlow = "auto"
# List the spId values that should use the scope flow
scopeConsentedApps = ["<spId-1>", "<spId-2>"]
# List the spId values that should use the purpose flow
purposeConsentedApps = ["<spId-3>"]
# Fallback URL for client_ids not in either list — sessionDataKeyConsent and spId are appended
defaultIdpConsentPage = "https://localhost:9443/authenticationendpoint/oauth2_consent.do"

openfgcBaseUrl = "http://localhost:8080"
orgId = "<openfgc-org-id>"
tppClientId = "<openfgc-tpp-client-id>"
consentType = "smart-consent"

alwaysAllowedScopes = ["openid"]

singleConsentPerUser = false
showConsentElements = true

# Scope flow: OpenFGC wrapper names (defaults shown — override only if needed)
[scopeConsent]
purposeName = "SMART Scope Authorization"
elementName  = "scope-access"

# Purpose flow: define one or more [[purposeConsent]] blocks
[[purposeConsent]]
name = "All Health Data Access"
description = "Access your health data related to USCDI."
mandatory = false
elements = [
    "MedicationDispense", "Coverage", "CareTeam", "RelatedPerson", "DiagnosticReport",
    "PractitionerRole", "Goal", "MedicationRequest", "Location", "CarePlan",
    "Provenance", "Patient", "Observation", "Condition", "ServiceRequest",
    "QuestionnaireResponse", "Medication", "Immunization", "Specimen", "Procedure",
    "Practitioner", "Organization", "Device", "AllergyIntolerance", "DocumentReference",
    "Encounter"
]
