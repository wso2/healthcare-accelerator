# Asgardeo tenant domain (e.g. "anjucha")
tenantDomain = "<asgardeo-tenant-slug>"

# Allowed CORS origin for the consent app UI (no trailing slash)
corsAllowedOrigin = "http://localhost:5175"

# OAuth2 client credentials — used to obtain an application access token
# via the client credentials grant before calling the Asgardeo identity APIs
clientId = "<oauth2-client-id>"
clientSecret = "<oauth2-client-secret>"

# Set to true to enforce one active consent per user per app (look up existing, update on re-submit)
singleConsentPerUser = true

# Set to false to hide individual elements from the consent UI — user approves the whole purpose at once
# showConsentElements = true

# OpenFGC consent service configuration
orgId = "<org-id>"
tppClientId = "<tpp-client-id>"
consentType = "<consent-type>"
openfgcBaseUrl = "<openfgc-base-url>"

# Consent purposes — add more [[consentPurpose]] blocks for additional purposes
[[consentPurpose]]
name = "All Health Data Access"
description = "Access your health data related to USCDI."
mandatory = false
elements = [
    "MedicationDispense", "Coverage", "CareTeam", "RelatedPerson", "DiagnosticReport",
    "PractitionerRole", "Goal", "MedicationRequest", "Location", "CarePlan",
    "Provenance", "Patient", "Observation", "Condition", "ServiceRequest",
    "QuestionnaireResponse", "Medication", "Immunization", "Specimen", "Procedure",
    "Practitioner", "Organization", "Device", "AllergyIntolerance", "DocumentReference",
    "Encounter"
]